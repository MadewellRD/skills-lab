{
  "name": "@skill-lab/compiler-core",
  "version": "0.1.0",
  "description": "Skill-Lab IR parser, validator, and graph resolver. The compiler core for converting SKILL.md files into validated in-memory representations ready for target adapters.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./parser": "./dist/parser.js",
    "./validator": "./dist/validator.js",
    "./types": "./dist/types.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-fixture": "tsx src/cli.ts"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "semver": "^7.6.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/semver": "^7.5.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
